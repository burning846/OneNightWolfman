# 监听端口
PORT=4000

# 允许的前端来源（逗号分隔），生产环境必填具体域名。开发可留空。
# 例：CORS_ORIGIN=https://your-app.vercel.app,https://wolf.example.com
CORS_ORIGIN=

# ---------- 用户系统（可选）----------
# 不设置 DATABASE_URL，则用户系统自动禁用，匿名玩法仍可用。
# Postgres 连接串，例如来自 Neon / Supabase / Render Postgres：
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Neon / Supabase / Render 默认启用 SSL；本地 Postgres 可关掉：
# DATABASE_SSL=false
DATABASE_SSL=

# JWT 签名密钥。生产环境务必设一个长且随机的字符串。
# 没设的话会用一个临时随机值（服务重启就让所有 token 失效）。
# JWT_SECRET=$(openssl rand -hex 32)
JWT_SECRET=
